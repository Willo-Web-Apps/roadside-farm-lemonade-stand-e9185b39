---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sunny Side Stand — Farm-Fresh Eggs & Lemonade",
  description = "Stop by our roadside farm stand for freshly gathered eggs and hand-squeezed lemonade. Run by the kids of Clover Hill Farm on Route 9."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Sunny Side Stand",
      "description": "Farm-fresh eggs and hand-squeezed lemonade sold at a roadside stand by the kids of Clover Hill Farm.",
      "url": "https://roadside-farm-lemonade-stand.onrender.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Route 9, Mile Marker 14"
      },
      "openingHours": ["Mo-Fr 15:00-18:00", "Sa-Su 09:00-13:00"],
      "priceRange": "$"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface-50 text-surface-900 font-body antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
